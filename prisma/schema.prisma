generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String               @id @default(cuid())
  name                  String
  email                 String               @unique
  password              String
  role                  String               @default("staff")
  tokenVersion          Int                  @default(0)
  createdAt             DateTime             @default(now())
  invoices              Invoice[]
  activityLogs          ActivityLog[]
  resetTokens           PasswordResetToken[]
  purchaseBillsCreated  PurchaseBill[]       @relation("PurchaseBillCreator")
  stockMovementsCreated StockMovement[]      @relation("StockMovementCreator")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String
  details    String
  entityId   String?
  entityType String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Customer {
  id        String    @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  city      String?
  state     String?
  pincode   String?
  gstin     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  invoices  Invoice[]
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  deletedAt DateTime?
  products  Product[]
}

model Brand {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  products  Product[]
}

model Product {
  id                String             @id @default(cuid())
  name              String
  description       String?
  sku               String?            @unique
  barcode           String?
  hsn               String?
  unit              String             @default("Nos")
  price             Float
  purchasePrice     Float?
  gstRate           Float              @default(18)
  stock             Int                @default(0)
  minStock          Int                @default(5)
  maxStock          Int?
  reorderLevel      Int?
  categoryId        String?
  brandId           String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  invoiceItems      InvoiceItem[]
  returnItems       ReturnItem[]
  purchaseBillItems PurchaseBillItem[]
  stockMovements    StockMovement[]
  brand             Brand?             @relation(fields: [brandId], references: [id])
  category          Category?          @relation(fields: [categoryId], references: [id])
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  date          DateTime      @default(now())
  dueDate       DateTime?
  customerId    String
  userId        String
  status        String        @default("unpaid")
  subtotal      Float
  cgst          Float         @default(0)
  sgst          Float         @default(0)
  igst          Float         @default(0)
  total         Float
  paidAmount    Float         @default(0)
  notes         String?
  isInterState  Boolean       @default(false)
  placeOfSupply String?
  reverseCharge Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?
  customer      Customer      @relation(fields: [customerId], references: [id])
  createdBy     User          @relation(fields: [userId], references: [id])
  items         InvoiceItem[]
  payments      Payment[]
  returns       Return[]
}

model InvoiceItem {
  id                String  @id @default(cuid())
  invoiceId         String
  productId         String
  name              String
  hsn               String  @default("")
  quantity          Float
  unit              String
  price             Float
  discountPercent   Float   @default(0)
  discountAmount    Float   @default(0)
  gstRate           Float
  gstAmount         Float
  total             Float
  invoice           Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product           Product @relation(fields: [productId], references: [id])
}

model Payment {
  id        String   @id @default(cuid())
  invoiceId String
  amount    Float
  method    String   @default("cash")
  reference String?
  date      DateTime @default(now())
  notes     String?
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Return {
  id        String       @id @default(cuid())
  invoiceId String
  invoice   Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  date      DateTime     @default(now())
  notes     String?
  createdAt DateTime     @default(now())
  items     ReturnItem[]
}

model ReturnItem {
  id        String   @id @default(cuid())
  returnId  String
  return    Return   @relation(fields: [returnId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  name      String
  quantity  Float
  price     Float
  total     Float
}

model BusinessSettings {
  id              String   @id @default("singleton")
  name            String   @default("Science Hub")
  tagline         String   @default("")
  email           String   @default("")
  phone           String   @default("")
  address         String   @default("")
  city            String   @default("")
  state           String   @default("")
  pincode         String   @default("")
  gstin           String   @default("")
  pan             String   @default("")
  gmailUser       String   @default("")
  gmailAppPassword String  @default("")
  bankName        String   @default("")
  bankAccountName String   @default("")
  bankAccountNumber String @default("")
  bankIfsc        String   @default("")
  bankBranch      String   @default("")
  termsAndConditions String @default("Interest @ 24%p.a would be charged after 45 days of Invoice\nMaterial sold strictly for lab use only\nWe are not responsible for any loss in transit.\nSubject to 'Delhi' Jurisdiction only.")
  updatedAt       DateTime @updatedAt
}

// ── Vendor Management ─────────────────────────────────────────────────────────

model Vendor {
  id            String          @id @default(cuid())
  name          String
  company       String?
  gstin         String?
  phone         String?
  email         String?
  address       String?
  notes         String?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?
  purchaseBills PurchaseBill[]
}

// ── Purchase Bills ────────────────────────────────────────────────────────────

model PurchaseBill {
  id              String            @id @default(cuid())
  billNumber      String            @unique
  vendorId        String
  vendor          Vendor            @relation(fields: [vendorId], references: [id])
  billDate        DateTime          @default(now())
  dueDate         DateTime?
  subtotal        Float             @default(0)
  taxAmount       Float             @default(0)
  discount        Float             @default(0)
  total           Float
  paidAmount      Float             @default(0)
  status          String            @default("unpaid")   // unpaid | partial | paid | cancelled
  notes           String?
  attachmentUrl   String?
  attachmentName  String?
  category        String?
  createdByUserId String
  createdBy       User              @relation("PurchaseBillCreator", fields: [createdByUserId], references: [id])
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  items           PurchaseBillItem[]
  payments        PurchasePayment[]
  stockMovements  StockMovement[]

  @@index([vendorId])
  @@index([status])
  @@index([billDate])
}

model PurchaseBillItem {
  id             String       @id @default(cuid())
  purchaseBillId String
  purchaseBill   PurchaseBill @relation(fields: [purchaseBillId], references: [id], onDelete: Cascade)
  productId      String?
  product        Product?     @relation(fields: [productId], references: [id])
  name             String
  quantity         Float
  unit             String       @default("Nos")
  purchasePrice    Float
  discountPercent  Float        @default(0)
  discountAmount   Float        @default(0)
  gstRate          Float        @default(0)
  gstAmount        Float        @default(0)
  total            Float
}

// ── Purchase Payments ─────────────────────────────────────────────────────────

model PurchasePayment {
  id             String       @id @default(cuid())
  purchaseBillId String
  purchaseBill   PurchaseBill @relation(fields: [purchaseBillId], references: [id], onDelete: Cascade)
  amount         Float
  method         String       @default("cash")
  reference      String?
  date           DateTime     @default(now())
  notes          String?
  createdAt      DateTime     @default(now())

  @@index([purchaseBillId])
}

// ── Stock Movement Ledger ─────────────────────────────────────────────────────

model StockMovement {
  id             String        @id @default(cuid())
  productId      String?
  product        Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName    String        @default("")
  type           String        // purchase | sale | adjustment | return | manual
  quantity       Float         // positive = stock in, negative = stock out
  balanceAfter   Float
  reference      String?
  notes          String?
  purchaseBillId String?
  purchaseBill   PurchaseBill? @relation(fields: [purchaseBillId], references: [id])
  createdByUserId String?
  createdBy      User?         @relation("StockMovementCreator", fields: [createdByUserId], references: [id])
  createdAt      DateTime      @default(now())

  @@index([productId])
  @@index([createdAt])
}
